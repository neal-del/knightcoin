# KnightCoin Environment Variables
# Copy this file to .env and fill in your values

# Sepolia RPC (Alchemy recommended)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# KnightCoin ERC-20 contract address on Sepolia
# Leave empty to disable on-chain features (off-chain KC still works)
KC_CONTRACT_ADDRESS=0x37C397fB96302Dbb09C091754eC51Eaf0bCB6024

# Deployer private key (only needed for contract deployment, NOT for running the app)
# DEPLOYER_PRIVATE_KEY=your_private_key_here

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:port/database
